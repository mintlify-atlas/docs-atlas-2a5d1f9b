  "keyFeatures": [
    "Mix-and-match ability drafting from any Dota 2 hero",
    "Hundreds of custom and modded abilities",
    "Extensive mutator system (vampirism, kill streak, random spells, and more)",
    "Bot AI support with configurable difficulty",
    "Community skill build sharing with voting and favorites",
    "Troll combo detection and balance bans",
    "Hero perks system tied to selected abilities",
    "In-game chat voting system for game options",
    "Cheat/debug command suite for testing",
    "Server-side stat and settings persistence"
  ],
  "publicApiSurface": [
    "POST /saveOptions — persist player settings by Steam ID",
    "POST /loadOptions — retrieve player settings by Steam ID",
    "POST /createSkillBuild — submit a new community skill build",
    "POST /removeSkillBuild — delete a skill build",
    "GET  /getSkillBuilds — list all community skill builds",
    "POST /setFavoriteSkillBuild — favorite/unfavorite a build",
    "POST /voteSkillBuild — upvote or downvote a skill build",
    "GET  /getFavoriteSkillBuilds — get a player's favorited builds",
    "Commands.OnPlayerChat — in-game chat command handler",
    "Pregame:init — initialise pre-game phase",
    "Ingame:init — initialise in-game phase",
    "OptionManager:GetOption / SetOption — read and write game options",
    "util:CreateVoting — start a player vote",
    "util:DisplayError — send an error message to a player"
  ]
}
